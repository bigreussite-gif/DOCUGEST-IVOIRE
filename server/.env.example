PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Déploiement tout-en-un sur Vercel (API serverless + front) : dans le dashboard Vercel,
# ajoute aussi CLIENT_ORIGIN=https://docugest-ivoire.vercel.app, INSFORGE_DATABASE_URL, JWT_SECRET.
# Tu n’as plus besoin de BACKEND_URL ni d’un 4ᵉ hébergeur (Render, etc.).

# PostgreSQL InsForge (dashboard projet → chaîne de connexion)
# Si défini, l’API utilise la base distante ; sinon fichiers JSON dans local-inforge-dev/
# DATABASE_URL=postgres://...
# INSFORGE_DATABASE_URL=postgres://...
# PGSSL=1

# Premier compte super-admin : après migration SQL, l’email ci-dessous reçoit le rôle super_admin au prochain login.
# ADMIN_BOOTSTRAP_EMAIL=toi@exemple.com

# JWT
JWT_SECRET=

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Inforge dev (stockage local)
# (par défaut: ./local-inforge-dev)
INFORGE_DEV_DIR=

# URL frontend (pour les liens de reset)
APP_URL=http://localhost:5173

# En prod, déclare aussi l’URL Vercel (séparées par des virgules) pour CORS et cookies.
# CLIENT_ORIGIN=https://docugest-ivoire.vercel.app,http://localhost:5173

