PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL InsForge (dashboard projet → chaîne de connexion)
# Si défini, l’API utilise la base distante ; sinon fichiers JSON dans local-inforge-dev/
# DATABASE_URL=postgres://...
# INSFORGE_DATABASE_URL=postgres://...
# PGSSL=1

# JWT
JWT_SECRET=

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Inforge dev (stockage local)
# (par défaut: ./local-inforge-dev)
INFORGE_DEV_DIR=

# URL frontend (pour les liens de reset)
APP_URL=http://localhost:5173

