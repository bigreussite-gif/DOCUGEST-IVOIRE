# =============================================================================
# DocuGest Ivoire — variables pour déploiement GitHub → Vercel + Postgres Insforge
# Copier vers le tableau Vercel : Project → Settings → Environment Variables
# =============================================================================

# --- Obligatoire (Insforge : chaîne Postgres) ---
# Une seule suffit ; Insforge fournit souvent INSFORGE_DATABASE_URL ou DATABASE_URL
DATABASE_URL=
# INSFORGE_DATABASE_URL=
# POSTGRES_URL=

# --- Obligatoire (JWT sessions / cookies) ---
JWT_SECRET=

# --- Optionnel (domaines supplémentaires pour CORS) ---
# Vercel injecte automatiquement VERCEL_URL et VERCEL_PROJECT_PRODUCTION_URL (domaine prod court).
# Si besoin d’origines en plus : CLIENT_ORIGIN=https://autre-domaine.com

# --- Optionnel (liens dans les emails ; sinon domaine prod Vercel) ---
# APP_URL=https://votre-app.vercel.app

# --- Optionnel (emails bienvenue / reset mot de passe ; sans SMTP les comptes fonctionnent quand même) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- Optionnel (premier admin bootstrap en base) ---
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# =============================================================================
# Build frontend (Vite) — Production
# Laisser VIDE : le client appelle /api sur la même origine (recommandé sur Vercel).
# VITE_API_BASE_URL=
# VITE_APP_URL=

# Dev local uniquement (npm run dev côté client) :
# VITE_API_BASE_URL=http://localhost:4000
# VITE_APP_URL=http://localhost:5173
