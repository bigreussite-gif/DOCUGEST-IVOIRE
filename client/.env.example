# Next.js — variables publiques (préfixe NEXT_PUBLIC_)
# Dev : API Express locale
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# URL publique du site (SEO, Open Graph, sitemap, JSON-LD). Dev : port Next (souvent 3000).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optionnel — Google Search Console (vérification de propriété)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Production (Vercel) : laisser vides pour same-origin /api ; définir NEXT_PUBLIC_APP_URL avec votre domaine canonique.
