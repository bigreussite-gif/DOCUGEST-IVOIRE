# Next.js — variables publiques (préfixe NEXT_PUBLIC_)
# Dev : API Express pour /api/documents uniquement — les routes /api/auth/* restent toujours sur Next (JWT).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# URL publique du site (SEO, Open Graph, sitemap, JSON-LD). Dev : port Next (souvent 3000).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optionnel — Google Search Console (vérification de propriété)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Production Vercel (liens officiels du projet) ---
# URL canonique à utiliser pour NEXT_PUBLIC_APP_URL (SEO, partages) :
# NEXT_PUBLIC_APP_URL=https://docugest-ivoire.vercel.app
# Déploiement projet Vercel (même app, URL technique) :
# https://docugest-ivoire-idngkehs5-bigreussite-gifs-projects.vercel.app
# Ne pas utiliser d’autres domaines de prévisualisation pour la prod.
