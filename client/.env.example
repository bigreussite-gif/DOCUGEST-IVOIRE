# API Express locale (routes /api/auth, /api/documents)
VITE_API_BASE_URL=http://localhost:4000
VITE_APP_URL=http://localhost:5173

# Backend InsForge (SDK / migration) — ne remplace pas VITE_API_BASE_URL tant que l’app utilise l’API Express
VITE_INSFORGE_URL=https://d5rjfctn.us-east.insforge.app

# Production (Vercel) : définir dans le dashboard, pas dans un fichier commité
# VITE_APP_URL=https://docugest-ivoire.vercel.app
# VITE_INSFORGE_URL=https://d5rjfctn.us-east.insforge.app
# Laisser VITE_API_BASE_URL vide : le front appellera le même domaine Vercel ; le proxy /api/* nécessite BACKEND_URL côté Vercel.
# Ou forcer l’URL de l’API : VITE_API_BASE_URL=https://ton-api.onrender.com
#
# Sur Vercel (Settings → Environment Variables) : BACKEND_URL=https://ton-api.onrender.com
# (URL de ton serveur Express seul, sans /api à la fin)

